<Window x:Class="KnizhnyMir.Desktop.OrdersManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книжный мир — Работа с заказами" Height="460" Width="560"
        MinHeight="400" MinWidth="480"
        Icon="/Resources/icon.ico"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Работа с заказами" FontSize="20" FontWeight="Bold"
                   Foreground="#FF4A3000" Margin="0,0,0,12" />

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Найти" Click="Find_Click" Width="90" />
            <TextBlock Text="Номер заказа:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="SearchNumberBox" VerticalAlignment="Center" />
        </DockPanel>

        <Border BorderBrush="#FFE0CFA0" BorderThickness="1" CornerRadius="6" Padding="16"
                VerticalAlignment="Top">
            <Grid x:Name="DetailsPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="OrderTitle" FontSize="18" FontWeight="Bold"
                           Foreground="#FF4A3000" Margin="0,0,0,12" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата заказа:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="OrderDateText" Margin="0,4" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="ФИО клиента:" FontWeight="SemiBold" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OrderClientText" Margin="0,4" TextWrapping="Wrap" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата доставки:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,4" />
                <DatePicker Grid.Row="3" Grid.Column="1" x:Name="DeliveryDatePicker" Width="180"
                            HorizontalAlignment="Left" Margin="0,4" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Статус заказа:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,4" />
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="StatusBox" Width="200"
                          HorizontalAlignment="Left" DisplayMemberPath="Name" Margin="0,4" />

                <Button Grid.Row="5" Grid.Column="1" Content="Сохранить изменения" Click="Save_Click"
                        HorizontalAlignment="Left" FontWeight="Bold" Margin="0,12,0,0" />
            </Grid>
        </Border>
    </DockPanel>
</Window>
